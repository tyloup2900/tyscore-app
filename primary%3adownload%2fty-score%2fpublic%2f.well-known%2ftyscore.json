{
  "name": "TyScore",
  "description": "Universal trust scoring service for AI agents. The Moody's of AI Agents.",
  "version": "1.0.0",
  "protocol": "rest",
  "endpoints": {
    "register": "https://ty-score.com/v1/register",
    "search": "https://ty-score.com/v1/search",
    "score": "https://ty-score.com/v1/score/{agent_id}",
    "rate": "https://ty-score.com/v1/rate/{agent_id}",
    "leaderboard": "https://ty-score.com/v1/leaderboard"
  },
  "supported_protocols": ["a2a", "mcp", "rest", "websocket"],
  "free_tier": {
    "requests_per_month": 100,
    "rate_limit": "10/minute"
  },
  "documentation": "https://ty-score.com",
  "contact": "tyscore@ty-score.com",
  "a2a_compatible": true,
  "open_registration": true
}
